# provider-stack/.env.example
#
# Copy to .env and fill in your secrets before starting the stack:
#   cp .env.example .env
#
# Items marked [CHANGE ME] MUST be replaced in any non-development deployment.
# All other values are safe defaults for local dev / Codespaces evaluation.

# ── External URL ─────────────────────────────────────────────────────────────
# Browser-facing base URL of this stack (port 8888).
# Local dev:     http://localhost:8888
# GitHub Codespaces: https://<codespace-name>-8888.app.github.dev
EXTERNAL_URL=http://localhost:8888

# ── Caddy ────────────────────────────────────────────────────────────────────
# Port exposed by the Docker container (used for the docker-compose port mapping).
CADDY_PORT=8888

# Site address for Caddy's virtual host / HTTPS cert domain.
#   Dev / Codespaces:  leave EMPTY → Caddy listens on :8888 (plain HTTP)
#   Production:        set to your FQDN, e.g. cdm.example.com
#                      Also set CADDY_AUTO_HTTPS=on and expose ports 80+443.
CADDY_SITE_ADDRESS=

# Set to "on" to enable automatic HTTPS via Let's Encrypt (production only).
# Requires CADDY_SITE_ADDRESS to be a publicly reachable FQDN.
CADDY_AUTO_HTTPS=off

# E-mail address sent to Let's Encrypt for cert expiry notifications (production).
CADDY_ACME_EMAIL=

# ── Keycloak ─────────────────────────────────────────────────────────────────
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=changeme          # [CHANGE ME]
KC_DB_PASSWORD=changeme             # [CHANGE ME]

# OIDC client secrets – must match values baked into the realm templates.
# Run `openssl rand -hex 32` to generate a fresh secret.
GRAFANA_OIDC_SECRET=changeme        # [CHANGE ME]
BRIDGE_OIDC_SECRET=changeme         # [CHANGE ME]
PORTAL_OIDC_SECRET=changeme         # [CHANGE ME]

# Bootstrap user passwords for the CDM realm
PROVIDER_OPERATOR_PASSWORD=changeme # [CHANGE ME]

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_ADMIN_USER=admin
RABBITMQ_ADMIN_PASSWORD=changeme    # [CHANGE ME]

# OIDC client secret for the RabbitMQ management UI → Keycloak SSO login.
# Run `openssl rand -hex 32` to generate a fresh secret and paste the same
# value into the Keycloak CDM realm import (rabbitmq-management client).
RABBITMQ_MANAGEMENT_OIDC_SECRET=changeme  # [CHANGE ME]

# ── TimescaleDB ─────────────────────────────────────────────────────────────
# PostgreSQL superuser password (= POSTGRES_PASSWORD inside the container)
TSDB_PASSWORD=changeme                   # [CHANGE ME]
# Write user password for Telegraf
TSDB_TELEGRAF_PASSWORD=changeme          # [CHANGE ME]
# Read-only user password for Grafana
TSDB_GRAFANA_PASSWORD=changeme           # [CHANGE ME]

# ── pgAdmin ──────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@cdm-platform.dev
PGADMIN_PASSWORD=changeme                # [CHANGE ME]
PGADMIN_OIDC_SECRET=changeme             # [CHANGE ME]

# ── Grafana ──────────────────────────────────────────────────────────────────
# No extra secrets needed – uses GRAFANA_OIDC_SECRET and TSDB_GRAFANA_PASSWORD above.

# ── IoT Bridge API ───────────────────────────────────────────────────────────
PORTAL_SESSION_SECRET=change-this-portal-session-secret  # [CHANGE ME]

# JSON map of tenants exposed in the portal (provider-stack default: cdm only)
# Add tenant entries when tenant-stacks are onboarded, e.g.:
# '{"cdm":{"name":"CDM Platform"},"acme":{"name":"Acme Devices GmbH"}}'
PORTAL_TENANTS_JSON={"cdm":{"name":"CDM Platform"}}

# ── step-ca (PKI) ────────────────────────────────────────────────────────────
STEP_CA_PKI_NAME=CDM Root CA
STEP_CA_DNS_NAMES=step-ca,localhost
STEP_CA_ADDRESS=:9000
STEP_CA_ADMIN_PROVISIONER=cdm-admin@cdm.local
STEP_CA_ENABLE_ACME=true
STEP_CA_ENABLE_REMOTE_MGMT=true
STEP_CA_ENABLE_SSH=false

# Set by iot-bridge-api after step-ca starts (fingerprint of root CA cert).
# Run: docker exec provider-step-ca step ca fingerprint
STEP_CA_FINGERPRINT=

# JWK provisioner used by iot-bridge-api to sign device certificates
STEP_CA_PROVISIONER_NAME=iot-bridge
STEP_CA_PROVISIONER_PASSWORD=changeme  # [CHANGE ME]
STEP_CA_ADMIN_PASSWORD=changeme        # [CHANGE ME]
STEP_CA_VERIFY_TLS=false

# ── OpenBao (Key Management) ─────────────────────────────────────────────────
# OpenBao provides a Transit secrets engine (key operations for step-ca),
# KV-v2 secrets storage and AppRole authentication for platform services.
# The UI is reachable at /vault/ (Caddy) or directly on port 8200.
#
# OPENBAO_MODE selects one of two supported modes:
#
#   standalone  (default) – single-node Raft server, no TPM required.
#                           Software-only unseal key stored in openbao-data volume.
#                           Suitable for development, CI, and single-node production.
#                           Alias "embedded" accepted for backward compatibility.
#
#   agent                 – OpenBao Agent proxy to an external Hub cluster.
#                           No local key material; all crypto operations happen at the Hub.
#                           Requires OPENBAO_HUB_ADDR and OPENBAO_APPROLE_* vars.
#                           See docs/security/hsm-agent-model.md and .env.ha-example.
OPENBAO_MODE=standalone
OPENBAO_PORT=8200

# Name of the Transit key created for step-ca key operations.
# Referenced when configuring the step-kms-plugin against this OpenBao instance.
OPENBAO_TRANSIT_KEY_NAME=step-ca      # Root CA key  (Transit engine, type: ecdsa-p256)
OPENBAO_TRANSIT_KEY_INT=step-ca-int  # Intermediate CA key (Transit engine, type: ecdsa-p256)

# Mount path for the KV-v2 platform secrets engine.
OPENBAO_KV_PATH=cdm

# AppRole credentials for step-ca.
# Auto-bootstrapped: OpenBao writes these to /openbao/data/step-ca-approle.json
# on first init; step-ca reads them automatically from the shared volume.
# Set explicitly here only to override the auto-bootstrapped values (e.g. after rotation).
OPENBAO_STEP_CA_ROLE_ID=     # [AUTO] override only if rotating credentials
OPENBAO_STEP_CA_SECRET_ID=   # [AUTO] override only if rotating  # [CHANGE ME] rotate regularly

# ── OpenBao Hub connection (only required when OPENBAO_MODE=agent) ───────────
# Set these when the Provider-Stack acts as a spoke that proxies to an external
# Hub cluster (production Hub-and-Spoke setup).
# See provider-stack/openbao/.env.ha-example for a complete example.
#OPENBAO_HUB_ADDR=https://openbao-hub.yourdomain.example:8200  # [CHANGE ME]
#OPENBAO_APPROLE_ROLE_ID=                                       # [CHANGE ME]
#OPENBAO_APPROLE_SECRET_ID=                                     # [CHANGE ME]
