# provider-stack/openbao/.env.ha-example
#
# Example environment configuration for the Hub-and-Spoke production setup.
#
# ─────────────────────────────────────────────────────────────────────────────
# SCENARIO: Provider-Stack as Agent Spoke → external Hub cluster
# ─────────────────────────────────────────────────────────────────────────────
#
# Prerequisites:
#   1. An external OpenBao Hub cluster is running and reachable.
#      (see docs/security/hsm-agent-model.md + hsm-disaster-recovery.md)
#   2. The Hub has been configured with:
#      a) Transit engine  →  key 'step-ca' (ECDSA P-256)
#      b) KV-v2 engine    →  mount 'cdm/'
#      c) AppRole auth    →  role 'cdm-provider-spoke'  bound to policy 'step-ca'
#   3. An AppRole role-id and a wrapped/plain secret-id have been issued by the Hub.
#
# Usage:
#   # In the provider-stack directory:
#   cp openbao/.env.ha-example .env.openbao-ha
#   # Fill in the real values, then merge into / override your provider-stack .env:
#   cat .env.openbao-ha >> .env
#   docker compose up -d
#
# Items marked  # [CHANGE ME]  must be replaced before use.
# ─────────────────────────────────────────────────────────────────────────────

# ── Switch OpenBao to Agent (Hub-and-Spoke) mode ─────────────────────────────
# The embedded single-node server is NOT started.
# Instead, an OpenBao Agent runs as a local proxy to the Hub.
# All existing service integrations (step-kms-plugin, AppRole secrets) work
# transparently – they still talk to http://openbao:8200 inside the stack.
OPENBAO_MODE=agent

# ── Hub address ──────────────────────────────────────────────────────────────
# URL of the external OpenBao Hub cluster.
# Use the VPN / WireGuard address if the Hub is on-premise.
OPENBAO_HUB_ADDR=https://openbao-hub.yourdomain.example:8200  # [CHANGE ME]

# ── AppRole credentials (generated on the Hub) ───────────────────────────────
# Generate via the Hub CLI or UI:
#   bao write -f auth/approle/role/cdm-provider-spoke/secret-id
OPENBAO_APPROLE_ROLE_ID=    # [CHANGE ME]  paste role-id from Hub
OPENBAO_APPROLE_SECRET_ID=  # [CHANGE ME]  paste secret-id from Hub  – rotate regularly

# ── Provider port (unchanged) ────────────────────────────────────────────────
OPENBAO_PORT=8200

# ── Engine configuration (must match Hub setup) ──────────────────────────────
# These values are used by other services that call the OpenBao API.
# They must match the Transit key name and KV-v2 mount configured on the Hub.
OPENBAO_TRANSIT_KEY_NAME=step-ca
OPENBAO_KV_PATH=cdm

# ── step-ca integration ───────────────────────────────────────────────────────
# The AppRole credentials below are used by step-ca (via step-kms-plugin) to
# authenticate against the Hub through the local Agent.
# Set these to the same AppRole or a more restricted role bound to the
# Transit sign/verify policy.
OPENBAO_STEP_CA_ROLE_ID=    # [CHANGE ME]
OPENBAO_STEP_CA_SECRET_ID=  # [CHANGE ME]

# ─────────────────────────────────────────────────────────────────────────────
# Tenant-Stack spoke example (tenant-stack/.env additions for agent mode):
# ─────────────────────────────────────────────────────────────────────────────
# COMPOSE_PROFILES=code-signing
# OPENBAO_MODE=agent
# OPENBAO_PORT=18200
# OPENBAO_HUB_ADDR=https://openbao-hub.yourdomain.example:8200  # [CHANGE ME]
# OPENBAO_APPROLE_ROLE_ID=    # [CHANGE ME] role for 'code-signer' policy on Hub
# OPENBAO_APPROLE_SECRET_ID=  # [CHANGE ME]
# OPENBAO_KV_PATH=code-signing
# OPENBAO_CODESIGN_KEY_NAME=code-signing
# OPENBAO_CODESIGN_ROLE_ID=    # [CHANGE ME]
# OPENBAO_CODESIGN_SECRET_ID=  # [CHANGE ME]
