# ─────────────────────────────────────────────────────────────────
# Tenant Stack – Environment Variables
#
# Copy to .env and fill in all [CHANGE ME] values before starting.
#
# Usage:
#   cp .env.example .env
#   # edit .env
#   docker compose up -d
#
# Lines marked  # [CHANGE ME]  MUST be changed in production.
# Lines marked  # [AUTO]       are generated automatically by services.
# ─────────────────────────────────────────────────────────────────

# ── Tenant identity ───────────────────────────────────────────────
# Unique short identifier for this tenant (lowercase, no spaces).
# Used as container name prefix, Keycloak realm name, TimescaleDB database name.
TENANT_ID=tenant1

# Human-readable display name shown in dashboards and landing pages.
TENANT_DISPLAY_NAME=Acme Devices GmbH

# Timezone for WireGuard container
TZ=Europe/Berlin

# ── External URLs ─────────────────────────────────────────────────
# Browser-facing URL for the Caddy entry point.
# In production: https://tenant1.iot.example.com
# In Codespaces: see runtime-computed value in caddy/html/index.html
#
# Port offset +10000 vs. provider-stack so both stacks can run side-by-side
# in the same environment (e.g. a single Codespace / development machine):
#   provider-stack uses the default ports (8888, 9090, 8000, …)
#   tenant-stack   uses +10000          (18888, 19090, 18000, …)
EXTERNAL_URL=http://localhost:18888

# ThingsBoard UI (port 19090 direct – cannot use sub-path due to SPA)
TB_EXTERNAL_URL=http://localhost:19090

# ── Host port overrides (+10000 offset) ───────────────────────────
# Remove or reset these to the defaults (without the leading 1) when running
# the tenant-stack in isolation without a co-located provider-stack.
CADDY_PORT=18888
KC_HOST_PORT=18080
STEP_CA_HOST_PORT=19000
TB_HOST_PORT=19090
TB_MQTT_TLS_HOST_PORT=18883
BRIDGE_HOST_PORT=18000
TERMINAL_HOST_PORT=18090
# WireGuard uses UDP and has no conflict with the provider-stack, so the
# standard port 51820 is kept even in side-by-side mode.
WG_PORT=51820

# ── Keycloak ──────────────────────────────────────────────────────
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=changeme                  # [CHANGE ME]
KC_DB_PASSWORD=changeme                     # [CHANGE ME]

# OIDC client secrets (32+ random chars; unique per tenant)
GRAFANA_OIDC_SECRET=changeme                # [CHANGE ME]
TB_OIDC_SECRET=changeme                     # [CHANGE ME]
HB_OIDC_SECRET=changeme                     # [CHANGE ME]
BRIDGE_OIDC_SECRET=changeme                 # [CHANGE ME]
PORTAL_OIDC_SECRET=changeme                 # [CHANGE ME]

# Tenant user passwords (bootstrap users in realm-tenant.json.tpl)
TENANT_ADMIN_EMAIL=admin@tenant.example.com
TENANT_ADMIN_PASSWORD=changeme              # [CHANGE ME]
TENANT_OPERATOR_EMAIL=operator@tenant.example.com
TENANT_OPERATOR_PASSWORD=changeme           # [CHANGE ME]
TENANT_VIEWER_EMAIL=viewer@tenant.example.com
TENANT_VIEWER_PASSWORD=changeme             # [CHANGE ME]

# Provider Keycloak federation (filled in after JOIN workflow)
# PROVIDER_KC_URL=https://provider.iot.example.com
# PROVIDER_KC_CLIENT_ID=tenant1-federation
# PROVIDER_KC_CLIENT_SECRET=                # [CHANGE ME] after JOIN

# ── ThingsBoard ───────────────────────────────────────────────────
TB_DB_PASSWORD=changeme                     # [CHANGE ME]
TB_SYSADMIN_EMAIL=sysadmin@thingsboard.org
TB_SYSADMIN_PASSWORD=sysadmin               # [CHANGE ME]

# MQTT TLS (set to true after step-ca Sub-CA is signed and TB certs are issued)
MQTT_SSL_ENABLED=false
# NONE = no client cert required; OPTIONAL = cert optional; REQUIRED = mTLS
MQTT_SSL_CLIENT_AUTHENTICATION=NONE

# ── hawkBit ──────────────────────────────────────────────────────
HB_DB_PASSWORD=changeme                     # [CHANGE ME]
HB_DB_ROOT_PASSWORD=changeme_root           # [CHANGE ME]
HB_ADMIN_USER=admin
HB_ADMIN_PASSWORD=admin                     # [CHANGE ME]

# hawkBit internal RabbitMQ (DMF bus only – not exposed outside tenant-net)
HB_RMQ_USER=admin
HB_RMQ_PASSWORD=changeme                    # [CHANGE ME]

# ── TimescaleDB ───────────────────────────────────────────────
TSDB_PASSWORD=changeme                      # [CHANGE ME] PostgreSQL superuser password
TSDB_TELEGRAF_PASSWORD=changeme             # [CHANGE ME] write user for Telegraf
TSDB_GRAFANA_PASSWORD=changeme              # [CHANGE ME] read-only user for Grafana

# ── pgAdmin ──────────────────────────────────────────────────
PGADMIN_EMAIL=admin@tenant.example.com
PGADMIN_PASSWORD=changeme                   # [CHANGE ME]

# Portal session secret (Express / Next.js session signing key)
PORTAL_SESSION_SECRET=change-this-portal-session-secret  # [CHANGE ME]

# ── step-ca (Tenant Issuing Sub-CA) ──────────────────────────────
STEP_CA_PKI_NAME=Tenant Sub-CA
STEP_CA_DNS_NAMES=step-ca,localhost
STEP_CA_ADMIN_PROVISIONER=tenant-admin@cdm.local
STEP_CA_ENABLE_ACME=true
STEP_CA_ENABLE_REMOTE_MGMT=true
STEP_CA_ADDRESS=:9000

# Sub-CA provisioner for IoT Bridge API (JWK provisioner)
STEP_CA_PROVISIONER_NAME=iot-bridge
STEP_CA_PROVISIONER_PASSWORD=changeme       # [CHANGE ME]

# Root password for the step-ca admin provisioner
STEP_CA_ADMIN_PASSWORD=changeme             # [CHANGE ME]

# After step-ca starts:
#   docker compose exec ${TENANT_ID}-step-ca step ca fingerprint
# and paste the value here so other services can bootstrap TLS trust.
STEP_CA_FINGERPRINT=                        # [AUTO] fill after first start

# ── Provider IoT Bridge API (JOIN handshake) ──────────────────────
# The Tenant-Stack performs a single authenticated handshake on first boot.
# Set PROVIDER_URL and JOIN_KEY before running `docker compose up` for the
# first time.
#
# How to obtain the JOIN key:
#   1. Open the CDM Dashboard (Provider-Stack) → Tenants → Prepare Tenant
#   2. Enter the tenant name – a single-use JOIN key (XXXX-YYYY-ZZZZ-WWWW)
#      is generated and shown once.
#   3. Paste it as JOIN_KEY below and set PROVIDER_URL to the Provider API URL.
#
# The Sub-CA CSR is generated locally on first boot, sent to the Provider with
# the JOIN key as credential, and the signed Sub-CA certificate is installed
# immediately.  The JOIN key is invalidated after use and can be removed.
PROVIDER_URL=                               # e.g. https://provider.iot.example.com/api   # [CHANGE ME]
JOIN_KEY=                                   # XXXX-YYYY-ZZZZ-WWWW (single-use, 7-day TTL) # [CHANGE ME]
TENANT_KEYCLOAK_URL=                        # e.g. https://tenant.iot.example.com/auth  (for KC federation)

# ── WireGuard ─────────────────────────────────────────────────────
# Publicly reachable hostname or IP for WireGuard.
# Use 'auto' to detect the public IP automatically.
WG_SERVER_URL=auto
# WG_PORT is set to 51820 (standard) – no conflict with provider-stack (UDP, different protocol).
WG_PEERS=10

# IMPORTANT: Each tenant MUST use a different VPN subnet.
# tenant1: 10.8.1.0   tenant2: 10.8.2.0   etc.
WG_INTERNAL_SUBNET=10.8.1.0
WG_SERVER_IP=10.8.1.1

# ── IoT Bridge API ────────────────────────────────────────────────
STEP_CA_VERIFY_TLS=false

# ── Grafana ───────────────────────────────────────────────────────
# No additional env needed – uses GRAFANA_OIDC_SECRET above.

# ── OpenBao (Code-Signing) ───────────────────────────────────────
# OpenBao is a mandatory service in every Tenant-Stack deployment.
# It manages the ECDSA P-384 code-signing key (Transit engine) and stores
# the code-signing certificate issued by the Tenant step-ca (KV-v2).
#
# OPENBAO_MODE controls the deployment mode:
#   embedded  – single-node Raft server; auto-init + auto-unseal.
#               The signing key lives inside this container's volume.
#               Suitable for development and isolated single-tenant setups.
#   agent     – OpenBao Agent proxy to an external Hub cluster (production).
#               The Hub holds the actual signing keys; this container
#               forwards all Transit/KV requests transparently.
#               Requires OPENBAO_HUB_ADDR + OPENBAO_APPROLE_* below.
#               See docs/security/hsm-agent-model.md for the full setup guide.
#
# Host port for the OpenBao API / UI (offset to 18200 for side-by-side with provider-stack)
OPENBAO_PORT=18200
# Production: set to agent and fill in Hub connection vars below.
OPENBAO_MODE=embedded

# Name of the Transit key used for code signing.
OPENBAO_CODESIGN_KEY_NAME=code-signing

# KV-v2 mount path where the code-signing certificate is stored.
OPENBAO_KV_PATH=code-signing

# Provisioner name in the Tenant step-ca for code-signing certificates.
STEP_CA_CODE_SIGNER_PROVISIONER=code-signer
STEP_CA_CODE_SIGNER_PASSWORD=changeme  # [CHANGE ME]

# AppRole credentials for CI/CD pipelines (auto-generated on first OpenBao boot).
# Read from the tenant-openbao container log or /openbao/data/.init.json.
OPENBAO_CODESIGN_ROLE_ID=     # [AUTO] fill after first start
OPENBAO_CODESIGN_SECRET_ID=   # [AUTO] fill after first start  # [CHANGE ME] rotate regularly

# ── OpenBao Hub connection (required when OPENBAO_MODE=agent) ────
# Set these to point this Tenant-Stack spoke at the central Hub cluster
# (on-site HA cluster or a customer-provided OpenBao/Vault instance).
# See docs/security/hsm-agent-model.md for the full setup guide.
#OPENBAO_HUB_ADDR=https://openbao-hub.yourdomain.example:8200   # [CHANGE ME]
#OPENBAO_APPROLE_ROLE_ID=                                        # [CHANGE ME]
#OPENBAO_APPROLE_SECRET_ID=                                      # [CHANGE ME]
